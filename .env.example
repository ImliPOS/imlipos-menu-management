# ---- Database (Supabase Postgres — DB only) ----
# Use the POOLED connection string (Supavisor/pgBouncer) for the long-running API.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require"

# ---- Supabase (Auth + Storage) ----
# Project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL="https://<ref>.supabase.co"
# Service-role / secret key (server-side ONLY — validates owner tokens + signs uploads).
SUPABASE_SERVICE_ROLE_KEY=""
# Storage bucket (create as public, with a file-size limit).
SUPABASE_STORAGE_BUCKET="menu-media"

# Browser-side Supabase (web app) — anon/publishable key is safe to expose.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---- TV device tokens (our own JWTs, owners use Supabase Auth instead) ----
# Generate a real one: openssl rand -hex 32  (use a DIFFERENT secret per env).
DEVICE_JWT_SECRET="a-long-random-string"

# ---- Service URLs ----
# URLs are NOT set here in deployments — they auto-derive from the branch via the
# shared map in packages/contracts/src/env.ts (dev branch → dev URLs, main → prod).
# Override only if you must:
#   APP_ENV=local|dev|prod           # force an environment
#   NEXT_PUBLIC_API_URL=...          # override the web app's API base
#   WEB_ORIGIN=...                   # override the API's CORS allow-list
#   SUPABASE_URL=...                 # override the API's Supabase project URL
