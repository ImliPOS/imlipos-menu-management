{
  "name": "imlipos",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "start": "pnpm --filter @imlipos/tv start",
    "tv": "pnpm --filter @imlipos/tv start",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @imlipos/api db:generate",
    "db:migrate": "pnpm --filter @imlipos/api db:migrate"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
